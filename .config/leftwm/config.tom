[[keybind]]
command = "MoveToTag"
value = "videos"
modifier = ["modkey", "Shift"]
key = "6"

[[keybind]]
command = "MoveToTag"
value = "games"
modifier = ["modkey", "Shift"]
key = "7"

[[keybind]]
command = "MoveToTag"
value = "vbox"
modifier = ["modkey", "Shift"]
