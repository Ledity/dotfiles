modkey = "Mod4"
mousekey = "Mod4"
workspaces = []
tags = ["web", "term", "other", "docs", "music", "video", "games", "vbox"]
layouts = [
    "MainAndVertStack",
    "RightWiderLeftStack",
    "CenterMain",
    "CenterMainBalanced",
    "EvenHorizontal",
    "Monocle"
]
scratchpad = []
disable_current_tag_swap = true
focus_behaviour = "ClickTo"
focus_new_windows = true

[[keybind]]
command = "HardReload"
modifier = ["modkey", "Shift", "Control"]
key = "r"

[[keybind]]
command = "SoftReload"
modifier = ["modkey", "Shift"]
key = "r"

[[keybinds]]
command = "Execute"
value = "logonctl kill-session $XDG_SESSION_ID"
modifier = ["modkey", "Shift"]
key = "x"

[[keybind]]
command = "CloseWindow"
modifier = ["modkey"]
key = "q"

[[keybind]]
command = "SetLayout"
value = "MainAndVertStack"
modifier = ["modkey"]
key = "a"

[[keybind]]
command = "SetLayout"
value = "RightWiderLeftStack"
modifier = ["modkey", "Shift"]
key = "a"

[[keybind]]
command = "SetLayout"
value = "CenterMainBalanced"
modifier = ["modkey"]
key = "d"

[[keybind]]
command = "SetLayout"
value = "CenterMain"
modifier = ["modkey", "Shift"]
key = "d"

[[keybind]]
command = "SetLayout"
value = "Monocle"
modifier = ["modkey"]
key = "s"

[[keybind]]
command = "SetLayout"
value = "Monocle"
modifier = ["modkey", "Shift"]
key = "s"

[[keybind]]
command = "FloatingToTile"
modifier = ["modkey"]
key = "e"

[[keybind]]
command = "MoveWindowTop"
modifier = ["modkey"]
key = "w"

[[keybind]]
command = "MoveWindowUp"
modifier = ["modkey", "Shift"]
key = "k"

[[keybind]]
command = "MoveWindowDown"
modifier = ["modkey", "Shift"]
key = "j"

[[keybind]]
command = "FocusWindowUp"
modifier = ["modkey"]
key = "k"

[[keybind]]
command = "FocusWindowDown"
modifier = ["modkey"]
key = "j"

[[keybind]]
command = "RotateTag"
modifier = ["modkey"]
key = "g"

[[keybind]]
command = "IncreaseMainWidth"
value = "5"
modifier = ["modkey", "Control"]
key = "k"

[[keybind]]
command = "DecreaseMainWidth"
value = "5"
modifier = ["modkey", "Control"]
key = "j"

[[keybind]]
command = "FocusNextTag"
modifier = ["modkey"]
key = "h"

[[keybind]]
command = "FocusPreviousTag"
modifier = ["modkey"]
key = "l"

[[keybind]]
command = "GoToTag"
value = "web"
modifier = ["modkey"]
key = "1"

[[keybind]]
command = "GoToTag"
value = "term"
modifier = ["modkey"]
key = "2"

[[keybind]]
command = "GoToTag"
value = "other"
modifier = ["modkey"]
key = "3"

[[keybind]]
command = "GoToTag"
value = "docs"
modifier = ["modkey"]
key = "4"

[[keybind]]
command = "GoToTag"
value = "music"
modifier = ["modkey"]
key = "5"

[[keybind]]
command = "GoToTag"
value = "videos"
modifier = ["modkey"]
key = "6"

[[keybind]]
command = "GoToTag"
value = "games"
modifier = ["modkey"]
key = "7"

[[keybind]]
command = "GoToTag"
value = "vbox"
modifier = ["modkey"]
key = "8"

[[keybind]]
command = "MoveToTag"
value = "web"
modifier = ["modkey", "Shift"]
key = "1"

[[keybind]]
command = "MoveToTag"
value = "term"
modifier = ["modkey", "Shift"]
