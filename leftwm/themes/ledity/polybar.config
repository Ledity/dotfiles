;   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
;   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
;   ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ    ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
;   ‚Ėą‚Ėą‚ēĎ     ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
;   ‚ēö‚ēź‚ēĚ      ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ
;
;
;   To learn more about how to configure Polybar
;   go to https://github.com/jaagr/polybar
;
;   The README contains a lot of information
;
;==========================================================

[colors]
background = #10151ad9
foreground = #cecece
background-alt = #141a21
foreground-alt = #ffffff
primary = #5294e2
secondary = #172a3d
red = #e25270
orange = #e2a052
yellow = #e2c552
salad = #b8e252
green = #52e258
cyan = #52e2c4
blue = #5294e2
bluish = #5454ff
purple = #7c52e2
pink = #e252dc

; --- bars --- ;

[bar/mainbar0]
inherit = bar/barbase
modules-left = workspace0
[module/workspace0]
type = custom/script
exec = leftwm-state -w 0 -t $SCRIPTPATH/template.liquid
tail = true

[bar/bottom0]
interhit = bar/bottombase
modules-left = workspace0

[bar/mainbar1]
inherit = bar/barbase
modules-left = workspace1
[module/workspace1]
type = custom/script
exec = leftwm-state -w 1 -t $SCRIPTPATH/template.liquid
tail = true

[bar/mainbar2]
inherit = bar/barbase
modules-left = workspace2
[module/workspace2]
type = custom/script
exec = leftwm-state -w 2 -t $SCRIPTPATH/template.liquid
tail = true

[bar/mainbar3]
inherit = bar/barbase
modules-left = workspace3
[module/workspace3]
type = custom/script
exec = leftwm-state -w 3 -t $SCRIPTPATH/template.liquid
tail = true

; --- barbase --- ;

[bar/barbase]
width = ${env:width}
offset-x = ${env:offsetx}
monitor = ${env:monitor}
;offset-y = ${env:y}
;width = 100%
height = 40
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 3
line-color = #f00
border-size = 0
border-color = #00000000
padding-left = 0
padding-right = 0
module-margin-left = 0
module-margin-right = 0
font-0 = Hack:size=13;1
font-1 = Font Awesome 5 Free:style=Solid:size=14
modules-center = date
modules-right = xkeyboard brightness pulseaudio cpu memory wlan eth battery
cursor-click = pointer
cursor-scroll = ns-resize
tray-position = none

[bar/bottombase]
width = ${env:width}
offset-x = ${env:offsetx}
monitor = ${env:monitor}
bottom = true
;offset-y = ${env:y}
;width = 100%
height = 40
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 3
line-color = #f00
border-size = 0
border-color = #00000000
padding-left = 0
padding-right = 0
module-margin-left = 0
module-margin-right = 0
font-0 = Hack:size=13;1
font-1 = Font Awesome 5 Free:style=Solid:size=14
modules-center = date
modules-right = cpu memory
cursor-click = pointer
cursor-scroll = ns-resize
tray-position = none

; --- modules-left --- ;

[module/rofi]
type = custom/script
interval = 100

exec = echo " ÔÄā "
tail = true

format-background = ${colors.secondary}
format-foreground = ${colors.cyan}
format-underline = ${colors.cyan}

click-left = rofi -show drun
click-right = rofi -show window
click-middle = rofi -show run

; --- modules-center --- ;

[module/date]
type = internal/date
interval = 1
date = " ÔĀ≥ %d.%m"
time = "ÔÄó %H:%M "

format-foreground = ${colors.foreground-alt}
label = %date% | %time%

; --- modules-right --- ;

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock
blacklist-1 = scroll lock

format = <label-layout>
format-spacing = 0
format-prefix = " ÔěĘ : "
format-prefix-foreground = ${colors.foreground-alt}
format-suffix = " "
format-suffix-foreground = ${colors.foreground-alt}

label-layout = %layout%

format-underline = ${colors.blue}
label-layout-foreground = ${colors.blue}

[module/brightness]
type = custom/script
interval = 0.25
exec = echo $(($(brightnessctl g)*100/255))"%"
tail = true
format-prefix = " ÔÉę : "
format-prefix-foreground = ${colors.foreground-alt}
format-suffix = " "
format-foreground = ${colors.salad}
format-underline = ${colors.salad}

click-left = brightnessctl s 0
click-right = brightnessctl s 30%
click-middle = brightnessctl s 255
scroll-up = brightnessctl s 5%+
scroll-down = brightnessctl s 5%-

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <ramp-volume> : <label-volume>
format-volume-prefix = " "
format-volume-prefix-foreground = ${colors.foreground-alt}
format-volume-suffix = " "
format-volume-suffix-foreground = ${colors.foreground-alt}

label-volume = %percentage%%
ramp-volume-0 = ÔÄ¶
ramp-volume-1 = ÔÄß
ramp-volume-2 = ÔÄ®

format-volume-underline = ${colors.bluish}
label-volume-foreground = ${colors.bluish}
ramp-volume-foreground = ${colors.foreground-alt}

label-muted = 0%
format-muted-prefix = " Ôö© : "
format-muted-prefix-foreground = ${colors.foreground-alt}
format-muted-suffix = " "
format-muted-suffix-foreground = ${colors.foreground-alt}

format-muted-underline = ${colors.pink}
label-muted-foreground = ${colors.pink}

[module/cpu]
type = internal/cpu
interval = 1
format-prefix = " Ôčõ : "
format-prefix-foreground = ${colors.foreground-alt}
format-suffix = " "
format-suffix-foreground = ${colors.foreground-alt}
format-foreground = ${colors.red}
format-underline = ${colors.red}
label = %percentage:%%

[module/memory]
type = internal/memory
interval = 1
format-prefix = " ÔĒł : "
format-prefix-foreground = ${colors.foreground-alt}
format-suffix = " "
format-suffix-foreground = ${colors.foreground-alt}
format-foreground = ${colors.yellow}
format-underline = ${colors.yellow}
label = %gb_used%

[module/wlan]
type = internal/network
interface = wlan0
interval = 1.0

format-connected-prefix = " Ôáę : "
format-connected-prefix-foreground = ${colors.foreground-alt}
format-connected-suffix = " "
format-connected-suffix-foreground = ${colors.foreground-alt}
format-connected = <label-connected>
format-connected-underline = ${colors.purple}
label-connected-foreground = ${colors.purple}
label-connected = %essid:0:7:..% ÔÄô %downspeed%

format-disconnected-prefix = " Ôáę : "
format-disconnected-prefix-foreground = ${colors.foreground-alt}
format-disconnected-suffix = " "
format-disconnected-suffix-foreground = ${colors.foreground-alt}
format-disconnected = <label-disconnected>
format-disconnected-foreground = ${colors.pink}
format-disconnected-underline = ${colors.pink}
label-disconnected = DISCONECTED
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/eth]
type = internal/network
interface = enp0s25
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = "ÓÜú "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

format-muted-prefix = "Óąā "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 2
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 98

format-charging-prefix = " "
format-charging-prefix-foreground = ${colors.foreground-alt}
format-charging-suffix = " "
format-charging-suffix-foreground = ${colors.foreground-alt}
format-charging = <animation-charging> : <label-charging>
label-charging-foreground = ${colors.green}
format-charging-underline = ${colors.green}

format-discharging-prefix = " "
format-discharging-prefix-foreground = ${colors.foreground-alt}
format-discharging-suffix = " "
format-discharging-suffix-foreground = ${colors.foreground-alt}
format-discharging = <ramp-capacity> : <label-discharging>
label-discharging-foreground = ${colors.orange}
format-discharging-underline = ${colors.orange}

format-full-prefix = " ÔČÄ : "
format-full-prefix-foreground = ${colors.foreground-alt}
format-full-suffix = " "
format-full-suffix-foreground = ${colors.foreground-alt}
format-full = <label-full>
format-full-foreground = ${colors.green}
format-full-underline = ${colors.green}

ramp-capacity-0 = ÔČĄ
ramp-capacity-1 = ÔČÉ
ramp-capacity-2 = ÔČā
ramp-capacity-3 = ÔČĀ
ramp-capacity-4 = ÔČÄ
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = ÔČĄ
animation-charging-1 = ÔČÉ
animation-charging-2 = ÔČā
animation-charging-3 = ÔČĀ
animation-charging-4 = ÔČÄ
animation-charging-framerate = 750
animation-charging-foreground = ${colors.foreground-alt}

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1
format-prefix = " "
format-suffix = " "

label-open = ÔÄĎ
label-open-foreground = ${colors.foreground-alt}
label-close = ÓĀ• cancel
label-close-foreground = ${colors.foreground-alt}
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
;pseudo-transparency = false

;[global/wm]
;margin-top = 5
;margin-bottom = 5

; vim:ft=dosini
