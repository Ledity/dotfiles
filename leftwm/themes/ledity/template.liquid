%{A}
{% elsif tag.busy %}
%{A1:$SCRIPTPATH/change_to_tag {{workspace.index}} {{tag.index}}:}
%{u#E2C552}%{+u}%{B#10151A}%{F#FFFFFF} [%{F-}%{F#E2C552}{{tag.name}}%{F-}%{F#FFFFFF}] %{F-}%{B-}%{u-}
%{A}
{% else tag.visible  %}
%{A1:$SCRIPTPATH/change_to_tag {{workspace.index}} {{tag.index}}:}
%{u#10151A}%{+u}%{B#10151A}%{F#FFFFFF} [%{F-}%{F#CECECE}{{tag.name}}%{F-}%{F#FFFFFF}] %{F-}%{B-}%{u-}
%{A}
{% endif %}
{% endfor %}
