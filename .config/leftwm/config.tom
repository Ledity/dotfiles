[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag web' && firefox"
modifier = ["modkey"]
key = "b"

[[keybind]]
command = "Execute"
value = "firefox"
modifier = ["modkey", "Shift"]
key = "b"

[[keybind]]
command = "ToggleScratchPad"
value = "Alacritty"
modifier = ["modkey", "Shift"]
key = "Enter"

[[keybind]]
execute = "ToggleScratchPad"
value = "leftwm-command 'GoToTag term' 'ToggleScratchPad Alacritty'"
modifier = ["modkey"]
key = "Enter"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag other' && pcmanfm-qt"
modifier = ["modkey"]
key = "f"

[[keybind]]
command = "Execute"
value = "pcmanfm-qt"
modifier = ["modkey", "Shift"]
key = "f"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag other' && kcalc"
modifier = ["modkey"]
key = "c"

[[keybind]]
command = "Execute"
value = "kcalc"
modifier = ["modkey", "Shift"]
key = "c"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag video' 'ToggleScratchPad VLC'"
modifier = ["modkey"]
key = "v"

[[keybind]]
command = "Execute"
value = "leftwm-command 'ToggleScratchPad VLC'"
modifier = ["modkey", "Shift"]
key = "v"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag video' 'ToggleScratchPad cmus'"
modifier = ["modkey"]
key = "v"

[[keybind]]
command = "Execute"
value = "leftwm-command 'ToggleScratchPad cmus'"
modifier = ["modkey", "Shift"]
key = "v"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag docs' && libreoffice"
modifier = ["modkey"]
key = "o"

[[keybind]]
command = "Execute"
value = "libreoffice"
modifier = ["modkey", "Shift"]
key = "o"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag vbox' && virtualbox"
modifier = ["modkey"]
key = "y"

[[keybind]]
command = "Execute"
value = "virtualbox"
modifier = ["modkey", "Shift"]
key = "y"

[[keybind]]
command = "Execute"
value = "leftwm-command 'GoToTag games' && steam"
