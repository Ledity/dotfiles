{% for tag in workspace.tags %}
{% if tag.mine %}
%{A1:$SCRIPTPATH/change_to_tag {{workspace.index}} {{tag.index}}:}
%{u#5294E2}%{+u}%{B#10151A}%{F#FFFFFF} [%{F-}%{F#5294E2}{{tag.name}}%{F-}%{F#FFFFFF}] %{F-}%{B-}%{u-}
%{A}
{% elsif tag.visible  %}
%{A1:$SCRIPTPATH/change_to_tag {{workspace.index}} {{tag.index}}:}
